# GigaChat API (Vite exposes VITE_* to the client bundle)
# Базовый URL GigaChat API
VITE_GIGACHAT_BASE_URL=https://gigachat.devices.sberbank.ru/api/v1

# OAuth endpoint для получения access_token (client_credentials)
VITE_GIGACHAT_OAUTH_URL=

# Либо укажите готовый access token (без префикса Bearer)
VITE_GIGACHAT_ACCESS_TOKEN=

# Либо укажите Basic credentials (Base64 от client_id:client_secret)
VITE_GIGACHAT_CREDENTIALS_BASE64=

# Scope: GIGACHAT_API_PERS | GIGACHAT_API_B2B | GIGACHAT_API_CORP
VITE_GIGACHAT_SCOPE=GIGACHAT_API_PERS
